# ── Local development only ────────────────────────────────────────────────────
# Copy this file to .env.local for local development.
# NEVER commit .env.local — it is already in .gitignore.
#
# In Cloudflare Pages: environment variables are set in the dashboard:
#   Cloudflare Dashboard → Pages → insightpulse → Settings → Environment variables
#
# VITE_API_URL is only needed for local dev (Vite's dev proxy uses it).
# In production, Cloudflare Pages _redirects handles /api/* → backend — no URL baked in.

VITE_API_URL=http://localhost:8000
