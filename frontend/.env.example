# ── InsightPulse — Environment Variables ────────────────────────────────────
# Copy this file to .env.local for local development.
# NEVER commit .env.local — it is in .gitignore.
#
# ── Production (Netlify) ─────────────────────────────────────────────────────
# In production, VITE_API_URL is intentionally left blank.
# Netlify's netlify.toml proxy rule handles /api/* → Render backend.
# No backend URL is baked into the built JS bundle.
#
# To set env vars in Netlify:
#   Netlify Dashboard → ana-pulse → Site configuration → Environment variables
#
# ── Local Development ────────────────────────────────────────────────────────
# Set VITE_API_URL to point the Vite dev proxy at your local or remote backend.

VITE_API_URL=http://localhost:8000
