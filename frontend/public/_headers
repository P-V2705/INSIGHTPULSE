# ── InsightPulse — Netlify _headers ──────────────────────────────────────────
# Security and caching headers for ana-pulse.netlify.app
# These supplement the headers defined in netlify.toml.

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-XSS-Protection: 1; mode=block
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# Aggressively cache content-hashed static assets (1 year, immutable)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

# Never cache the HTML entry point
/index.html
  Cache-Control: public, max-age=0, must-revalidate
